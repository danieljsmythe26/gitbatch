#!/usr/bin/env bash
set -euo pipefail

REPO="${GITBATCH_REPO:-$HOME/Documents/coding/gitbatch}"
BINARY="${GITBATCH_BINARY:-$HOME/.local/bin/gitbatch}"
SCAN_DIR="${GITBATCH_SCAN_DIR:-$HOME/Documents/coding}"
STATE_DIR="${GITBATCH_STATE_DIR:-$HOME/.local/share/gitbatch}"
INSTALLED_COMMIT_FILE="$STATE_DIR/installed-commit"

installed_commit() {
  if [[ -f "$INSTALLED_COMMIT_FILE" ]]; then
    head -n 1 "$INSTALLED_COMMIT_FILE"
  fi
}

master_commit() {
  git -C "$REPO" rev-parse --short master
}

current_commit() {
  git -C "$REPO" rev-parse --short HEAD
}

write_installed_commit() {
  mkdir -p "$STATE_DIR"
  current_commit > "$INSTALLED_COMMIT_FILE"
}

require_clean_tree() {
  if ! git -C "$REPO" diff --quiet || ! git -C "$REPO" diff --cached --quiet; then
    echo "gitbatch repo has uncommitted changes."
    echo "Commit, stash, or discard them before running: gb update"
    exit 1
  fi
}

require_master() {
  local branch
  branch="$(git -C "$REPO" branch --show-current)"
  if [[ "$branch" != "master" ]]; then
    echo "gitbatch repo is on '$branch', not 'master'."
    echo "Switch to master before running: gb update"
    exit 1
  fi
}

build_binary() {
  go -C "$REPO" build -o "$BINARY" ./cmd/gitbatch
  write_installed_commit
}

warn_if_behind() {
  local installed local_master
  installed="$(installed_commit || true)"
  local_master="$(master_commit || true)"

  if [[ -z "$installed" || -z "$local_master" || "$installed" == "$local_master" ]]; then
    return
  fi

  cat <<EOF
gb is behind local gitbatch master
installed: $installed
local:     $local_master

Run: gb update
Continuing in 2s...
EOF
  sleep 2
}

case "${1:-}" in
  update)
    require_clean_tree
    require_master
    echo "Updating gitbatch"
    echo "repo: $REPO"
    git -C "$REPO" pull --ff-only origin master
    build_binary
    echo "installed: $(installed_commit)"
    echo "binary:    $BINARY"
    ;;
  install)
    build_binary
    echo "installed current checkout: $(installed_commit)"
    echo "binary: $BINARY"
    ;;
  --help|-h|help)
    cat <<EOF
Usage:
  gb           Launch gitbatch for $SCAN_DIR
  gb update    Pull latest master and rebuild the installed binary
  gb install   Rebuild the installed binary from the current checkout
EOF
    ;;
  *)
    warn_if_behind
    exec "$BINARY" -d "$SCAN_DIR" -r 1 "$@"
    ;;
esac
